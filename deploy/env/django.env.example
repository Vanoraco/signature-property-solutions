# Install as /etc/sps/django.env with mode 0640. Never commit the real values.
SECRET_KEY=REPLACE_WITH_A_NEW_RANDOM_SECRET
DEBUG=False
DJANGO_SETTINGS_MODULE=sps_settings
PYTHONPATH=/etc/sps
ALLOWED_HOSTS=signaturepropertysolutions.com,www.signaturepropertysolutions.com,admin.signaturepropertysolutions.com,127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=https://signaturepropertysolutions.com,https://www.signaturepropertysolutions.com,https://admin.signaturepropertysolutions.com
CORS_ALLOWED_ORIGINS=https://signaturepropertysolutions.com,https://www.signaturepropertysolutions.com,https://admin.signaturepropertysolutions.com
SITE_URL=https://signaturepropertysolutions.com
SITE_NAME="Signature Property Solutions"
ADMIN_URL=admin/
DATABASE_PATH=/var/lib/sps/db.sqlite3
MEDIA_ROOT=/var/lib/sps/media
STATIC_ROOT=/var/www/signature-property-solutions/statics
