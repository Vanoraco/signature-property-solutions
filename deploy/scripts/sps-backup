#!/usr/bin/env bash
set -Eeuo pipefail
umask 0077

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
if [[ -r "$SCRIPT_DIR/common.sh" ]]; then
  # shellcheck source=common.sh
  source "$SCRIPT_DIR/common.sh"
else
  # shellcheck source=/usr/local/lib/sps-deploy/common.sh
  source /usr/local/lib/sps-deploy/common.sh
fi

require_root
require_user
require_commands sqlite3 tar sha256sum flock git
load_env_file "$DJANGO_ENV_FILE"

DATABASE_PATH="${DATABASE_PATH:-${STATE_DIR}/db.sqlite3}"
MEDIA_ROOT="${MEDIA_ROOT:-${STATE_DIR}/media}"

install -d -m 0700 -o root -g root "$BACKUP_ROOT"
exec 8>"$BACKUP_LOCK_FILE"
flock -n 8 || die "Another SPS backup is already running."

timestamp="$(date --utc '+%Y%m%dT%H%M%SZ')"
commit="unknown"
if [[ -d "$APP_DIR/.git" ]]; then
  commit="$(run_as_app git -C "$APP_DIR" rev-parse HEAD 2>/dev/null || printf 'unknown')"
fi

backup_dir="${BACKUP_ROOT}/${timestamp}-${commit:0:12}"
[[ ! -e "$backup_dir" ]] || die "Backup destination already exists: $backup_dir"
staging_dir="$(mktemp -d "${BACKUP_ROOT}/.tmp.${timestamp}.XXXXXX")"

cleanup() {
  if [[ -n "${staging_dir:-}" && -d "$staging_dir" && "$staging_dir" == "$BACKUP_ROOT"/.tmp.* ]]; then
    rm -rf -- "$staging_dir"
  fi
}
trap cleanup EXIT

database_present=false
media_present=false

if [[ -f "$DATABASE_PATH" ]]; then
  [[ "$staging_dir/db.sqlite3" != *"'"* ]] || die "Unsafe backup path."
  sqlite3 "$DATABASE_PATH" ".timeout 10000" ".backup '$staging_dir/db.sqlite3'"
  integrity="$(sqlite3 "$staging_dir/db.sqlite3" 'PRAGMA integrity_check;')"
  [[ "$integrity" == "ok" ]] || die "SQLite integrity check failed: $integrity"
  database_present=true
else
  log "Database does not exist yet; recording an empty-state backup."
fi

if [[ -d "$MEDIA_ROOT" ]]; then
  tar --create --gzip --file "$staging_dir/media.tar.gz" --directory "$MEDIA_ROOT" .
  media_present=true
else
  log "Media directory does not exist yet; recording an empty-state backup."
fi

cat >"$staging_dir/manifest.env" <<EOF
created_at=${timestamp}
git_commit=${commit}
database_path=${DATABASE_PATH}
media_root=${MEDIA_ROOT}
database_present=${database_present}
media_present=${media_present}
EOF

(
  cd "$staging_dir"
  files=(manifest.env)
  [[ -f db.sqlite3 ]] && files+=(db.sqlite3)
  [[ -f media.tar.gz ]] && files+=(media.tar.gz)
  sha256sum "${files[@]}" >SHA256SUMS
)

mv -- "$staging_dir" "$backup_dir"
staging_dir=""
trap - EXIT

log "Backup completed: $backup_dir"
printf '%s\n' "$backup_dir"
